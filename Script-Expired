-- ── Floating particles ──
local function spawnParticle()
    local p = Instance.new("Frame", g)
    local size = math.random(2, 5)
    p.Size = UDim2.fromOffset(size, size)
    p.Position = UDim2.new(math.random(), 0, 1.05, 0)
    p.BackgroundColor3 = math.random() > 0.5 and C.PR or C.SC
    p.BackgroundTransparency = math.random(65, 88) / 100
    p.BorderSizePixel = 0
    p.ZIndex = 0
    Instance.new("UICorner", p).CornerRadius = UDim.new(1, 0)
    T:Create(p, TweenInfo.new(math.random(7, 13), Enum.EasingStyle.Linear), {
        Position = UDim2.new(math.random(), 0, -0.05, 0),
        BackgroundTransparency = 1
    }):Play()
    task.delay(13, function() if p and p.Parent then p:Destroy() end end)
end

task.spawn(function()
    while g and g.Parent do spawnParticle() task.wait(0.5) end
end)

