local function toast(msg, dur)
    local t = Instance.new("Frame", g)
    t.Size = UDim2.fromOffset(280, 50)
    t.Position = UDim2.new(1, -300, 0, 20)
    t.BackgroundColor3 = C.SF
    t.BackgroundTransparency = 0.1
    t.BorderSizePixel = 0
    Instance.new("UICorner", t).CornerRadius = UDim.new(0, 12)

    local grad = Instance.new("UIGradient", t)
    grad.Color = ColorSequence.new{ColorSequenceKeypoint.new(0, C.GR1), ColorSequenceKeypoint.new(1, C.GR2)}
    grad.Rotation = 45

    local txt = Instance.new("TextLabel", t)
    txt.Size = UDim2.fromScale(1, 1)
    txt.BackgroundTransparency = 1
    txt.Text = msg
    txt.TextColor3 = C.TX
    txt.TextSize = 13
    txt.Font = Enum.Font.GothamBold
    txt.TextWrapped = true
    Instance.new("UIPadding", txt).PaddingLeft = UDim.new(0, 12)

    T:Create(t, TweenInfo.new(0.4, Enum.EasingStyle.Back), {Position = UDim2.new(1, -300, 0, 20)}):Play()
    task.delay(dur or 3, function()
        T:Create(t, TweenInfo.new(0.3), {Position = UDim2.new(1, 20, 0, 20), BackgroundTransparency = 1}):Play()
        T:Create(txt, TweenInfo.new(0.3), {TextTransparency = 1}):Play()
        task.wait(0.3)
        t:Destroy()
    end)
end

